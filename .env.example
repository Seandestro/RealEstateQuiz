# ─────────────────────────────────────────────────────────────
# RealEstateQuiz — Environment Variables
# Copy this file to .env and fill in your API keys.
# EXPO_PUBLIC_* vars are embedded at build time and accessible
# client-side via process.env.EXPO_PUBLIC_*
# ─────────────────────────────────────────────────────────────

# FRED (Federal Reserve Economic Data)
# Powers: 30-yr mortgage rate, Fed Funds rate
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
EXPO_PUBLIC_FRED_API_KEY=your_fred_api_key_here

# Walk Score API
# Powers: Walk Score, Transit Score, Bike Score
# Free tier (5,000 req/day): https://www.walkscore.com/professional/api.php
EXPO_PUBLIC_WALKSCORE_API_KEY=your_walkscore_api_key_here

# BLS (Bureau of Labor Statistics)
# Powers: San Diego & national unemployment rates
# No key required for v1. For higher rate limits, register free at:
# https://data.bls.gov/registrationEngine/
# Then set this and update src/services/bls.ts to use v2
EXPO_PUBLIC_BLS_API_KEY=optional_bls_key_for_v2
